# Database
DATABASE_URL="postgresql://user:pass@localhost:5432/citofono?schema=public"

# Auth — generate with: openssl rand -base64 32
SESSION_SECRET="change-me-in-production"

# ─────────── AI Provider (concierge) ───────────
# Scegli UN provider: anthropic | openai | google | xai | groq | ollama | openrouter
# Default: anthropic. Cambialo + setta la corrispondente API key.
CITOFONO_AI_PROVIDER="anthropic"
# Sovrascrivi il modello (opzionale; ogni provider ha un default).
# CITOFONO_AI_MODEL="claude-haiku-4-5-20251001"
# Legacy alias rispettato per backwards-compat:
# CITOFONO_CONCIERGE_MODEL="..."

# Anthropic Claude — default. Modelli: claude-haiku-4-5, claude-sonnet-4-6, claude-opus-4-7
ANTHROPIC_API_KEY="sk-ant-..."

# OpenAI — modelli: gpt-5-nano (cheap), gpt-5, gpt-5-mini, gpt-4o, gpt-4o-mini
# OPENAI_API_KEY="sk-..."
# OPENAI_BASE_URL="https://api.openai.com/v1"  # raro override

# xAI Grok — modelli: grok-4-fast (cheap), grok-4
# XAI_API_KEY="xai-..."

# Google Gemini — modelli: gemini-2.5-flash (default), gemini-2.5-pro
# GOOGLE_API_KEY="..."  # alternativo: GEMINI_API_KEY

# Groq (Llama velocissimo) — modelli: llama-3.3-70b-versatile, llama-3.1-8b-instant
# GROQ_API_KEY="gsk_..."

# OpenRouter (router unificato) — qualsiasi modello
# OPENROUTER_API_KEY="sk-or-..."

# Ollama (modelli locali, gratis se hai una GPU) — modelli: llama3.3, qwen2.5:7b, mistral-nemo, phi-4
# OLLAMA_HOST="http://localhost:11434"

# ─────────── Storage ───────────
# S3 storage (Cloudflare R2 or AWS S3). In dev fallback su filesystem locale.
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="citofono-dev"
S3_ENDPOINT="https://<account>.r2.cloudflarestorage.com"
S3_REGION="auto"

# ─────────── Email (Resend) ───────────
# Senza RESEND_API_KEY le email vanno in console (dev mode).
RESEND_API_KEY=""
EMAIL_FROM="noreply@citofono.app"

# ─────────── Stripe ───────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_HOST="price_..."
STRIPE_PRICE_HOST_PLUS="price_..."

# ─────────── Cron (Vercel) ───────────
CRON_SECRET=""

# ─────────── Public ───────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Citofono"
